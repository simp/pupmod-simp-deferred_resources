{
  "name": "simp-deferred_resources",
  "version": "1.0.1",
  "author": "simp",
  "summary": "This module creates custom types used to add resources to the catalog after the compilation of the manifests",
  "license": "Apache-2.0",
  "source": "https://github.com/simp/pupmod-simp-deferred_resources",
  "project_page": "https://github.com/simp/pupmod-simp-deferred_resources",
  "issues_url": "https://github.com/simp/pupmod-simp-deferred_resources/issues",
  "tags": [
    "simp"
  ],
  "dependencies": [
    {
      "name": "simp/simplib",
      "version_requirement": ">= 4.9.0 < 6.0.0"
    },
    {
      "name": "puppetlabs/stdlib",
      "version_requirement": ">= 8.0.0 < 10.0.0"
    }
  ],
  "operatingsystem_support": [
    {
      "operatingsystem": "CentOS",
      "operatingsystemrelease": [
        "9",
        "10"
      ]
    },
    {
      "operatingsystem": "RedHat",
      "operatingsystemrelease": [
        "8",
        "9",
        "10"
      ]
    },
    {
      "operatingsystem": "OracleLinux",
      "operatingsystemrelease": [
        "8",
        "9",
        "10"
      ]
    },
    {
      "operatingsystem": "Rocky",
      "operatingsystemrelease": [
        "8",
        "9",
        "10"
      ]
    },
    {
      "operatingsystem": "AlmaLinux",
      "operatingsystemrelease": [
        "8",
        "9",
        "10"
      ]
    }
  ],
  "requirements": [
    {
      "name": "openvox",
      "version_requirement": ">= 8.0.0 < 9.0.0"
    }
  ]
}
